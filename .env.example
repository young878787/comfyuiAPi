# AI Provider: github | google
AI_PROVIDER=github

# GitHub Models API
GITHUB_API_TOKEN=your_github_token_here
GITHUB_API_URL=https://models.github.ai/inference/chat/completions
GITHUB_MODEL=gpt-5

# Google AI Studio API (used when AI_PROVIDER=google)
# Get your API key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
GOOGLE_MODEL=gemma-4-27b-it

# Prompt Template: qwen | anima
# qwen  -> 青少女角色設計師，workflow: qwen image.json (Steps=12, CFG=1.0)
# anima -> Anima 動漫模型設計師，workflow: Anima.json  (Steps=35, CFG=4.0)
PROMPT_TEMPLATE=qwen

# ComfyUI API
COMFYUI_API_URL=http://127.0.0.1:8188
# COMFYUI_WORKFLOW_PATH is auto-derived from PROMPT_TEMPLATE (uncomment to override)
# COMFYUI_WORKFLOW_PATH=./workflow/qwen image.json

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
SESSION_STORAGE_PATH=./sessions
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# Default Image Parameters
DEFAULT_IMAGE_WIDTH=608
DEFAULT_IMAGE_HEIGHT=1328
DEFAULT_STEPS=12
DEFAULT_CFG=1.0
DEFAULT_SAMPLER=dpmpp_2m_sde_gpu
DEFAULT_SCHEDULER=simple

# Frontend (Vue 3 build output)
FRONTEND_DIR=./frontend/dist
